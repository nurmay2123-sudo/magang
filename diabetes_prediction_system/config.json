                },
                {
                    "id": "kolesterol_tinggi",
                    "question": "Apakah Anda pernah didiagnosis mengidap kolesterol tinggi?",
                    "type": "select",
                    "feature": "HighChol",
                    "options": [
                        {"value": "tidak", "label": "Tidak"},
                        {"value": "ya", "label": "Ya"}
                    ]
                },
                {
                    "id": "cek_kolesterol_5tahun",
