{
    "model_type": "random_forest",
    "model_name": "Diabetes Prediction Model",
    "version": "1.0.0",
    "created_date": "2026-06-06",
    "threshold": {
        "low": 0.18,
        "medium": 0.36
    },
    "display_threshold": {
        "low": 0.25,
        "medium": 0.50,
        "description": "Threshold untuk tampilan user (0-100%). threshold model 0.36 dipetakan ke 50% tampilan"
    },
    "features": [
        "HighBP",
        "HighChol",
        "CholCheck",
        "BMI",
        "PhysActivity",
        "GenHlth"
    ],
    "feature_descriptions": {
        "HighBP": "Tekanan darah tinggi (0=Tidak, 1=Ya)",
        "CholCheck": "Pemeriksaan kolesterol dalam 5 tahun (0=Tidak, 1=Ya)",
        "GenHlth": "Kesehatan umum (1=Sangat Baik s/d 5=Sangat Buruk)",
        "PhysActivity": "Aktif berolahraga (0=Tidak, 1=Ya)",
        "HighChol": "Kolesterol tinggi (0=Tidak, 1=Ya)",
        "BMI": "Indeks Massa Tubuh"
    },
    "section_questions": {
        "Data Kesehatan Dasar": {
            "description": "Informasi dasar tentang kesehatan Anda",
            "questions": [
                {
                    "id": "usia",
                    "question": "Berapa usia Anda saat ini?",
                    "type": "number",
                    "feature": "BMI",
                    "min": 18,
                    "max": 100,
                    "placeholder": "Misal: 45"
                },
                {
                    "id": "berat_badan",
                    "question": "Berapa berat badan Anda saat ini (kg)?",
                    "type": "number",
                    "feature": "BMI",
                    "min": 30,
                    "max": 200,
                    "placeholder": "Misal: 70"
                },
                {
                    "id": "tinggi_badan",
                    "question": "Berapa tinggi badan Anda (cm)?",
                    "type": "number",
                    "feature": "BMI",
                    "min": 120,
                    "max": 220,
                    "placeholder": "Misal: 170"
                },
                {
                    "id": "lingkar_pinggang",
                    "question": "Berapa ukuran lingkar pinggang Anda (cm)?",
                    "type": "number",
                    "feature": "BMI",
                    "min": 50,
                    "max": 200,
                    "placeholder": "Misal: 85"
                },
                {
                    "id": "riwayat_diabetes_keluarga",
                    "question": "Apakah ada anggota keluarga yang mengidap diabetes?",
                    "type": "select",
                    "feature": "BMI",
                    "options": [
                        {"value": "tidak", "label": "Tidak ada"},
                        {"value": "saudara", "label": "Ada (saudara kandung)"},
                        {"value": "orang_tua", "label": "Ada (orang tua)"},
                        {"value": "kakek_nenek", "label": "Ada (kakek/nenek)"},
                        {"value": "semua", "label": "Ada (multiple keluarga)"}
                    ]
                },
                {
                    "id": "jenis_kelamin",
                    "question": "Apa jenis kelamin Anda?",
                    "type": "select",
                    "feature": "BMI",
                    "options": [
                        {"value": "laki_laki", "label": "Laki-laki"},
                        {"value": "perempuan", "label": "Perempuan"}
                    ]
                }
            ]
        },
