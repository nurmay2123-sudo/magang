                    "feature": "HighChol",
                    "options": [
                        {"value": "ya", "label": "Ya"},
                        {"value": "tidak", "label": "Tidak"}
                    ]
                },
                {
                    "id": "obat_hipertensi",
                    "question": "Apakah Anda sedang mengonsumsi obat tekanan darah tinggi?",
                    "type": "select",
                    "feature": "HighBP",
                    "options": [
                        {"value": "tidak", "label": "Tidak"},
                        {"value": "ya", "label": "Ya"}
                    ]
                }
            ]
        },
        "Gaya Hidup": {
            "description": "Informasi tentang gaya hidup dan aktivitas harian Anda",
            "questions": [
                {
                    "id": "frekuensi_olahraga",
                    "question": "Berapa sering Anda berolahraga dalam seminggu?",
                    "type": "select",
                    "feature": "PhysActivity",
                    "options": [
                        {"value": "tidak_pernah", "label": "Tidak pernah"},
                        {"value": "1_kali", "label": "1 kali seminggu"},
                        {"value": "2_3_kali", "label": "2-3 kali seminggu"},
                        {"value": "4_lebih", "label": "4 kali atau lebih"}
                    ]
                },
                {
                    "id": "aktivitas_fisik",
                    "question": "Apakah Anda melakukan aktivitas fisikminimal 30 menit setiap hari?",
                    "type": "select",
                    "feature": "PhysActivity",
                    "options": [
                        {"value": "tidak", "label": "Tidak"},
                        {"value": "ya", "label": "Ya"}
                    ]
                },
                {
                    "id": "merokok",
                    "question": "Apakah Anda merokok?",
                    "type": "select",
                    "feature": "PhysActivity",
                    "options": [
                        {"value": "tidak", "label": "Tidak pernah"},
                        {"value": "former", "label": "Mantan perokok"},
                        {"value": "ya", "label": "Ya, masih merokok"}
                    ]
                },
                {
                    "id": "konsumsi_alkohol",
                    "question": "Seberapa sering Anda mengonsumsi alkohol?",
                    "type": "select",
                    "feature": "GenHlth",
                    "options": [
                        {"value": "tidak", "label": "Tidak pernah"},
                        {"value": "jarang", "label": "Jarang (1-2x sebulan)"},
                        {"value": "sedang", "label": "Sedang (1-3x seminggu)"},
                        {"value": "sering", "label": "Sering (4x atau lebih seminggu)"}
                    ]
                },
                {
                    "id": "konsumsi_sayur",
                    "question": "Berapa porsi sayur dan buah yang Anda konsumsi setiap hari?",
                    "type": "select",
                    "feature": "GenHlth",
                    "options": [
                        {"value": "sangat_sedikit", "label": "Sangat sedikit (< 1 porsi)"},
                        {"value": "sedikit", "label": "Sedikit (1-2 porsi)"},
                        {"value": "cukup", "label": "Cukup (3-4 porsi)"},
                        {"value": "banyak", "label": "Banyak (5 porsi atau lebih)"}
                    ]
                },
                {
                    "id": "makanan_berlemak",
                    "question": "Seberapa sering Anda mengonsumsi makanan tinggi lemak?",
                    "type": "select",
                    "feature": "HighChol",
                    "options": [
                        {"value": "jarang", "label": "Jarang"},
                        {"value": "sedang", "label": "Sedang"},
                        {"value": "sering", "label": "Sering"},
                        {"value": "sangat_sering", "label": "Sangat sering"}
                    ]
                }
            ]
